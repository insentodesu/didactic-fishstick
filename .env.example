# ============================================================
# Общие настройки
# ============================================================
SECRET_KEY=измените-на-случайную-строку-не-менее-32-символов
ENVIRONMENT=development
DEBUG=true

# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=finassist
POSTGRES_USER=finassist
POSTGRES_PASSWORD=измените-пароль

# Строки подключения для каждого сервиса (отдельные схемы)
AUTH_DB_URL=postgresql+asyncpg://finassist:измените-пароль@postgres:5432/finassist
TRANSACTION_DB_URL=postgresql+asyncpg://finassist:измените-пароль@postgres:5432/finassist
SUBSCRIPTION_DB_URL=postgresql+asyncpg://finassist:измените-пароль@postgres:5432/finassist
INVESTMENT_DB_URL=postgresql+asyncpg://finassist:измените-пароль@postgres:5432/finassist
GAMIFICATION_DB_URL=postgresql+asyncpg://finassist:измените-пароль@postgres:5432/finassist
NOTIFICATION_DB_URL=postgresql+asyncpg://finassist:измените-пароль@postgres:5432/finassist
RECEIPT_DB_URL=postgresql+asyncpg://finassist:измените-пароль@postgres:5432/finassist
ANALYTICS_DB_URL=postgresql+asyncpg://finassist:измените-пароль@postgres:5432/finassist

# ============================================================
# ClickHouse (аналитические события)
# ============================================================
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ============================================================
# Redis
# ============================================================
REDIS_URL=redis://redis:6379/0
REDIS_SESSION_DB=0
REDIS_CACHE_DB=1
REDIS_CELERY_DB=2
REDIS_LEADERBOARD_DB=3

# ============================================================
# ChromaDB (векторная БД для RAG)
# ============================================================
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION_FINANCE=finance_docs
CHROMA_COLLECTION_TRANSACTIONS=user_transactions

# ============================================================
# AIESA LLM API (https://aiesa.ru)
# ============================================================
AIESA_BASE_URL=https://api.transcription.aiesa.ru/api/v2
AIESA_PUBLIC_KEY=pk_ваш_публичный_ключ
AIESA_SECRET_KEY=sk_ваш_секретный_ключ
AIESA_MODEL=aiesa-pro
AIESA_TIMEOUT=60

# ============================================================
# JWT
# ============================================================
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ============================================================
# Gmail OAuth2
# ============================================================
GMAIL_CLIENT_ID=your-google-client-id
GMAIL_CLIENT_SECRET=your-google-client-secret
GMAIL_REDIRECT_URI=http://localhost/api/auth/gmail/callback

# ============================================================
# ФНС API (расшифровка QR-кодов чеков)
# ============================================================
FNS_API_URL=https://proverkacheka.com/api/v1
FNS_CLIENT_SECRET=your-fns-secret

# ============================================================
# Celery
# ============================================================
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ============================================================
# Внутренние URL сервисов (для межсервисных запросов)
# ============================================================
AUTH_SERVICE_URL=http://auth-service:8001
TRANSACTION_SERVICE_URL=http://transaction-service:8002
ANALYTICS_SERVICE_URL=http://analytics-service:8003
SUBSCRIPTION_SERVICE_URL=http://subscription-service:8004
INVESTMENT_SERVICE_URL=http://investment-service:8005
GAMIFICATION_SERVICE_URL=http://gamification-service:8006
NOTIFICATION_SERVICE_URL=http://notification-service:8007
RECEIPT_SERVICE_URL=http://receipt-service:8008
LLM_SERVICE_URL=http://llm-service:8009

# ============================================================
# Загрузка файлов
# ============================================================
UPLOAD_DIR=/tmp/uploads
MAX_UPLOAD_SIZE_MB=50
